# ===========================================================================
# legal-council — root environment (consumed by docker-compose.yml)
# Copy to .env and fill in. `docker compose up` reads this automatically.
# ===========================================================================

# --- Local Postgres (pgvector) credentials -------------------------------
POSTGRES_USER=lexicon
POSTGRES_PASSWORD=lexicon
POSTGRES_DB=lexicon
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379

# --- Database URLs --------------------------------------------------------
# Python LLM service (SQLAlchemy/asyncpg form; main.py adapts the dialect).
# To use the REAL production dataset (case search + parity), point this at
# your Lexicon database instead of the local container.
DATABASE_URL=postgresql://lexicon:lexicon@postgres:5432/lexicon
# Go API (pgx form). Same database, pgx-style URL.
API_DATABASE_URL=postgres://lexicon:lexicon@postgres:5432/lexicon?sslmode=disable

# --- Redis ----------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- LLM wiring -----------------------------------------------------------
# Shared secret between Go API and Python LLM service (X-API-KEY header).
LLM_API_KEY=local-dev-key
# Go -> Python base URL (no path). In compose this is the service name.
LLM_SERVICE_URL=http://localhost:18001
# Google Gemini key — REQUIRED for the AI deliberation + embeddings to work.
GEMINI_API_KEY=

# --- Runtime --------------------------------------------------------------
ENVIRONMENT=development
TURNSTILE_ENABLED=false
OTEL_ENABLED=false

# Host port mappings
API_HOST_PORT=8000
LLM_HOST_PORT=8001
