# Python LLM service environment
# For running natively (`pnpm --filter llm dev`). In docker-compose these are
# supplied by the root .env instead.

# Database (SQLAlchemy/asyncpg form; main.py adapts the dialect and strips
# sslmode). Point at the real Lexicon DB to get the jurisprudence dataset.
DATABASE_URL=postgresql://lexicon:lexicon@localhost:5432/lexicon

# Shared secret — must match the Go API's LLM_API_KEY (checked as X-API-KEY).
LLM_API_KEY=local-dev-key

# Google Gemini API key — REQUIRED for deliberation + embeddings.
GEMINI_API_KEY=

# Models (defaults shown; override if needed)
LLM_MODEL=gemini/gemini-2.5-flash
LLM_ORCHESTRATOR_MODEL=gemini/gemini-2.5-flash
EMBEDDING_MODEL=gemini/gemini-embedding-001
EMBEDDING_DIMENSIONS=768

ENVIRONMENT=development
