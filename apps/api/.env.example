# Go API (council-only proxy) environment
# For running natively (`pnpm --filter api dev`). In docker-compose these are
# supplied by the root .env instead.

# Database (pgx form). Point at the real Lexicon DB for production parity.
DATABASE_URL=postgres://lexicon:lexicon@localhost:5432/lexicon?sslmode=disable

# Redis (rate limiting / bot detection)
REDIS_URL=redis://localhost:6379/0

# Python LLM service base URL (no path).
LLM_SERVICE_URL=http://localhost:8001
# Shared secret sent as X-API-KEY to the LLM service (must match llm's LLM_API_KEY)
LLM_API_KEY=local-dev-key
LLM_SERVICE_TIMEOUT=120s

# Server
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=info

# Cloudflare Turnstile (optional; disabled by default for local dev)
TURNSTILE_ENABLED=false
TURNSTILE_SECRET_KEY=

# Bot detection (optional)
BOT_DETECTION_ENABLED=false

# OpenTelemetry (optional)
OTEL_ENABLED=false
OTLP_ENDPOINT=
