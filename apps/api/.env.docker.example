# Docker Compose Environment Variables
# Copy this file to .env.docker and fill in the values

# Application
ENVIRONMENT=production
LOG_LEVEL=info
BASE_URL=https://api.lexicon.id

# Database (required)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@host.docker.internal:5432/postgres?sslmode=disable

# Redis (required)
REDIS_URL=redis://default:YOUR_PASSWORD@host.docker.internal:6379/1

# LLM Service (required)
LLM_SERVICE_URL=http://host.docker.internal:8001

# Chatbot Service (required)
CHATBOT_SERVICE_URL=https://chatbot.lexicon.id
CHATBOT_API_KEY=your-api-key-here
